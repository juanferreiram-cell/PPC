Servo Servo1; //Declaracion de Servomotor
Servo Servo2;
const int pinServo1 = 13; //Declaracion pin 13 en el servo
const int pinServo2 = 14; //Declaracion pin 14 en el servo
const int IN1 = 21;
const int IN2 = 22;
const int ENA = 23;
const int IN3 = 25;
const int IN4 = 26;
const int ENB = 27;
 //Inicializar posicion del Servo2


void setup() 
{
  RemoteXY_Init ();  // initialization by macros 
  Servo1.attach(pinServo1); //Inicializar posicion del Servo1 
  Servo2.attach(pinServo2);
  EEPROM.begin(RemoteXYEngine.getEepromSize()); // init EEPROM
  pinMode(IN1, OUTPUT);
  pinMode(IN2, OUTPUT);
  pinMode(IN3, OUTPUT);
  pinMode(IN4, OUTPUT);
  pinMode(ENA, OUTPUT);
  pinMode(ENB, OUTPUT);
}

void loop() 
{ 
    RemoteXYEngine.handler ();   
    int angulo1 = map(RemoteXY.ServoDer1, -100, 100, 0, 180);// TODO you setup code
    int angulo2 = map(RemoteXY.ServoDer2, -100, 100, 0, 180);// TODO you setup code

    Servo1.write(angulo1);
    Servo2.write(angulo2);

    if (RemoteXY.Avanzar == 1){
        avanzar();// TODO you loop code
    }
    if (RemoteXY.Retroceder == 1){
        retroceder();
    }
  
        // use the RemoteXY structure for data transfer
  // do not call delay(), use instead RemoteXYEngine.delay() 
}

void avanzar(void){
    digitalWrite(IN1, HIGH);
    digitalWrite(IN2, LOW);
    digitalWrite(IN3, HIGH);
    digitalWrite(IN4, LOW);
    analogWrite(ENA, 60);
    analogWrite(ENB, 60);// -
}

void retroceder(void){
    digitalWrite(IN1, LOW);
    digitalWrite(IN2, HIGH);
    digitalWrite(IN3, LOW);
    digitalWrite(IN4, HIGH);
    analogWrite(ENA, 60);
    analogWrite(ENB, 60);
}